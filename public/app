function saveBulkAll() {
  let n=0;
  G.bulkLeads.forEach(l=>{ if(!G.saved.find(x=>x.id===l.id)){G.saved.push(l);n++;} });
  persistSaved(); updateBadges(); showToast(`${n} leads saved`,'s'); renderSaved();
}

function exportBulk() { G.exportPool=G.bulkLeads; G.exportLimit=G.user?.limits?.exports||0; openExportModal(); }

// ── RENDER LEADS ───────────────────────────────────────────────────────────
function toggleFilter(name){
  G.filters[name]=!G.filters[name];
  const on=G.filters[name];
  const track=document.getElementById(name==='noWebsite'?'noWebTrack':'noPhoneTrack');
  const thumb=document.getElementById(name==='noWebsite'?'noWebThumb':'noPhoneThumb');
  if(track){track.style.background=on?'var(--accent)':'var(--bg4)';}
  if(thumb){thumb.style.transform=on?'translateX(16px)':'translateX(0)';thumb.style.background=on?'#fff':'var(--muted)';}
  if(G.leads.length) renderLeads();
}
function applyFilters(leads){
  let out=leads;
  // noWebsite filtering handled server-side when toggle is ON before search
  // noPhone filter removed
  return out;
}
function psc(s){return s>=70?'ph':s>=40?'pm':'pl';}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function renderLeads() {
  const _filtered=applyFilters(G.leads);
  const filterOn = G.filters.noWebsite;
  const rcText = filterOn
    ? `${G.leads.length} businesses without websites found`
    : `${_filtered.length} of ${G.leads.length} businesses found${_filtered.length < G.leads.length ? ' ('+G.leads.length+' total, filtering active)' : ''}`;
  document.getElementById('rc').textContent = rcText;
  document.getElementById('lb').innerHTML=_filtered.map(l=>`
    <tr class="${G.sel.has(l.id)?'sel':''} ${!l.website?'high-opp':''}" onclick="openD('${esc(l.id)}','main')">
      <td onclick="event.stopPropagation()"><input type="checkbox" ${G.sel.has(l.id)?'checked':''} style="accent-color:var(--accent);cursor:pointer" onchange="toggleSel('${esc(l.id)}',this)"></td>
      <td class="nm">${esc(l.name)}${!l.website?' <span class=\"ho-badge\">High Opportunity</span>':''}</td>
      <td class="mu">${esc(l.cat)}</td>
      <td class="mu">${esc(l.phone)||'—'}</td>
      <td class="${l.website?'lk':'mu'}">${l.website?`<a href="${esc(l.website)}" target="_blank" onclick="event.stopPropagation()">${esc(l.website.replace(/^https?:\/\//,'').slice(0,22))}</a>`:'<span style="color:var(--muted);font-size:11px">No website</span>'}</td>
      <td class="mu" title="${esc(l.address)}">${esc(l.address.slice(0,26))}${l.address.length>26?'…':''}</td>
      <td class="mu">${l.rating?l.rating+'★':'—'}</td>
      <td><span class="pill ${psc(l.score)}">${l.score}</span></td>
      <td style="display:flex;gap:4px;flex-wrap:wrap">
        <button class="btn btn-g" style="padding:3px 8px;font-size:10px" onclick="event.stopPropagation();quickSave('${esc(l.id)}','main')">Save</button>
        <button class="btn btn-p" style="padding:3px 8px;font-size:10px" onclick="event.stopPropagation();openOutreachModal('${esc(l.id)}','main')">✉ Outreach</button>
        <button class="btn btn-y" style="padding:3px 8px;font-size:10px" onclick="event.stopPropagation();archiveLead('${esc(l.id)}','main')">Archive</button>
      </td>
    </tr>`).join('');
  document.getElementById('tw').style.display='block';
  document.getElementById('rhdr').style.display='flex';
  // rc already set above with filter count
}

// ── SELECT ─────────────────────────────────────────────────────────────────
function toggleSel(id,cb){if(cb.checked)G.sel.add(id);else G.sel.delete(id);renderLeads();}
function toggleAll(cb){if(cb.checked)G.leads.forEach(l=>G.sel.add(l.id));else G.sel.clear();renderLeads();}
function selAll(){if(G.sel.size===G.leads.length)G.sel.clear();else G.leads.forEach(l=>G.sel.add(l.id));renderLeads();}

// ── SAVE ───────────────────────────────────────────────────────────────────
function quickSave(id, pool='main') {
  const src=pool==='bulk'?G.bulkLeads:G.leads;
  const l=src.find(x=>x.id===id);
  if(l&&!G.saved.find(x=>x.id===id)){
    G.saved.push({...l,crmStatus:'new',notes:''});
    persistSaved(); updateBadges(); showToast('Saved!','s'); renderSaved();
  }
}
function saveSelected(){let n=0;G.sel.forEach(id=>{const l=G.leads.find(x=>x.id===id);if(l&&!G.saved.find(x=>x.id===id)){G.saved.push({...l,crmStatus:'new',notes:''});n++;}});persistSaved();updateBadges();showToast(`${n} saved`,'s');renderSaved();}
function saveCurrent(){if(!G.cur)return;G.cur.notes=document.getElementById('drN').value;if(!G.saved.find(x=>x.id===G.cur.id)){G.saved.push(G.cur);updateBadges();}persistSaved();showToast('Saved!','s');renderSaved();renderCrm();}
function persistSaved(){localStorage.setItem('lg_saved',JSON.stringify(G.saved));}

// ── ARCHIVE ────────────────────────────────────────────────────────────────
function archiveLead(id, pool='main') {
  const src=pool==='bulk'?G.bulkLeads:G.leads;
  const l=src.find(x=>x.id===id);
  if(l&&!G.archived.find(x=>x.id===id)){
    G.archived.push(l);
    localStorage.setItem('lg_archived',JSON.stringify(G.archived));
  }
  if(pool==='main'){G.leads=G.leads.filter(x=>x.id!==id);renderLeads();}
  else{G.bulkLeads=G.bulkLeads.filter(x=>x.id!==id);renderBulkLeads();}
  updateBadges(); showToast('Archived','i'); renderArchive();
}
function archiveSelected(){G.sel.forEach(id=>archiveLead(id,'main'));G.sel.clear();}
function archiveCurrent(){if(!G.cur)return;archiveLead(G.cur.id,'main');closeDrawer();}
function clearArchive(){G.archived=[];localStorage.setItem('lg_archived','[]');updateBadges();renderArchive();showToast('Archive cleared','i');}
function renderArchive(){
  const w=document.getElementById('archiveTw'),e=document.getElementById('archiveEmpty');
  document.getElementById('archiveCount').textContent=G.archived.length+' leads';
  document.getElementById('archiveBadge').textContent=G.archived.length;
  if(!G.archived.length){w.style.display='none';e.style.display='flex';return;}
  e.style.display='none';w.style.display='block';
  document.getElementById('archiveBody').innerHTML=G.archived.map(l=>`
    <tr><td></td><td class="nm">${esc(l.name)}</td><td class="mu">${esc(l.cat)}</td>
    <td class="mu">${esc(l.phone)||'—'}</td><td class="mu">${esc(l.address.slice(0,26))}</td>
    <td class="mu">${l.rating?l.rating+'★':'—'}</td>
    <td><button class="btn btn-o" style="padding:3px 9px;font-size:10px" onclick="unarchive('${esc(l.id)}')">Restore</button></td></tr>`).join('');
}
function unarchive(id){const l=G.archived.find(x=>x.id===id);if(!l)return;G.archived=G.archived.filter(x=>x.id!==id);localStorage.setItem('lg_archived',JSON.stringify(G.archived));updateBadges();renderArchive();showToast('Restored','s');}

// ── SAVED VIEW ─────────────────────────────────────────────────────────────
