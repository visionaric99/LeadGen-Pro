function remSaved(id){G.saved=G.saved.filter(l=>l.id!==id);persistSaved();updateBadges();renderSaved();renderCrm();}

// ── CRM ────────────────────────────────────────────────────────────────────
const CRM_STAGES=[
  {id:'new',label:'New',color:'var(--muted)'},
  {id:'contacted',label:'Contacted',color:'var(--accent)'},
  {id:'interested',label:'Interested',color:'var(--yellow)'},
  {id:'closed',label:'Won 🎉',color:'var(--green)'},
  {id:'lost',label:'Lost',color:'var(--red)'}
];

function renderCrm(){
  const kanban=document.getElementById('kanban');
  kanban.innerHTML=CRM_STAGES.map(stage=>{
    const leads=G.saved.filter(l=>(l.crmStatus||'new')===stage.id);
    return `
      <div class="kol">
        <div class="kol-hdr" style="color:${stage.color}">${stage.label}<span class="kcount">${leads.length}</span></div>
        ${leads.map(l=>`
          <div class="kcard" onclick="openD('${esc(l.id)}','saved')">
            <div class="kcard-name">${esc(l.name)}</div>
            <div class="kcard-meta">${esc(l.cat)} · ${esc(l.city)}</div>
            <div class="kcard-meta">${esc(l.phone)||'No phone'}</div>
            <div class="kcard-actions">
              ${CRM_STAGES.filter(s=>s.id!==stage.id).map(s=>`
                <button class="btn btn-o" style="padding:2px 6px;font-size:10px;margin-bottom:2px" onclick="event.stopPropagation();moveCrm('${esc(l.id)}','${s.id}')">${s.label}</button>`).join('')}
            </div>
          </div>`).join('')}
      </div>`;
  }).join('');
}

function moveCrm(id,status){
  const l=G.saved.find(x=>x.id===id);
  if(l){l.crmStatus=status;persistSaved();renderCrm();renderSaved();}
}

function updateCrmStatus(){
  if(!G.cur)return;
  const status=document.getElementById('drCrmStatus').value;
  const saved=G.saved.find(x=>x.id===G.cur.id);
  if(saved){saved.crmStatus=status;G.cur.crmStatus=status;persistSaved();renderCrm();renderSaved();}
}

// ── DRAWER ─────────────────────────────────────────────────────────────────
function openD(id, pool='main'){
