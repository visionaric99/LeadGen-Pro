const G = {
  leads:[], saved:[], archived:[], sel:new Set(), cur:null,
  bulkLeads:[], bulkRows:[],
  token:localStorage.getItem('lg_token'),
  filters:{noWebsite:false,noPhone:false},
  user:JSON.parse(localStorage.getItem('lg_user')||'null'),
  exportLimit:0, exportPool:[]
};

// ── INIT ───────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  // Load saved/archived from localStorage
  G.saved = JSON.parse(localStorage.getItem('lg_saved')||'[]');
  G.archived = JSON.parse(localStorage.getItem('lg_archived')||'[]');
  updateBadges();
  initBulkRows();
  if (G.token && G.user) {
    showDashboard();
    if (location.search.includes('upgraded=true')) { refreshUser(); showToast('Plan upgraded!','s'); history.replaceState({},'','/'); }
  } else { showPage('landing'); }

  // Enter key search
  ['q','loc'].forEach(id => {
    document.getElementById(id)?.addEventListener('keydown', e => { if(e.key==='Enter') runSearch(); });
  });
});

// ── AUTH ───────────────────────────────────────────────────────────────────
async function doSignup() {
  const email=document.getElementById('signupEmail').value.trim(), password=document.getElementById('signupPass').value;
  const btn=document.getElementById('signupBtn'), err=document.getElementById('signupErr');
  err.classList.remove('on');
  if(!email||!password){showErr(err,'Fill in all fields');return;}
  btn.disabled=true; btn.textContent='Creating…';
  try {
    const res=await api('/api/signup','POST',{email,password});
    if(res.error){showErr(err,res.error);return;}
    setSession(res); showDashboard(); showToast('Welcome to LeadGen Pro!','s');
  } catch{showErr(err,'Network error');}
  finally{btn.disabled=false;btn.textContent='Create account';}
}

async function doLogin() {
  const email=document.getElementById('loginEmail').value.trim(), password=document.getElementById('loginPass').value;
  const btn=document.getElementById('loginBtn'), err=document.getElementById('loginErr');
  err.classList.remove('on');
  btn.disabled=true; btn.textContent='Logging in…';
  try {
    const res=await api('/api/login','POST',{email,password});
    if(res.error){showErr(err,res.error);return;}
    setSession(res); showDashboard(); showToast('Welcome back!','s');
  } catch{showErr(err,'Network error');}
  finally{btn.disabled=false;btn.textContent='Log in';}
}

function doLogout() { localStorage.removeItem('lg_token'); localStorage.removeItem('lg_user'); G.token=null; G.user=null; showPage('landing'); }
function setSession(d) { G.token=d.token; G.user={email:d.email,plan:d.plan,planLabel:d.planLabel,limits:d.limits}; localStorage.setItem('lg_token',d.token); localStorage.setItem('lg_user',JSON.stringify(G.user)); }
async function refreshUser() { const r=await api('/api/me','GET'); if(!r.error){G.user={...G.user,...r};localStorage.setItem('lg_user',JSON.stringify(G.user));updatePlanUI();} }
function showErr(el,msg){el.textContent=msg;el.classList.add('on');}

