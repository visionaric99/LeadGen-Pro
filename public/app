// ── COMMUNITY CHAT ────────────────────────────────────────────────────────
let chatWs = null;
let chatConnected = false;
let chatInited = false;

function initChat() {
  if (chatInited) return;
  chatInited = true;
  connectChat();
}

function connectChat() {
  const token = G.token || '';
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  const url = `${proto}//${location.host}?token=${encodeURIComponent(token)}`;

  chatWs = new WebSocket(url);

  chatWs.onopen = () => {
    chatConnected = true;
    document.getElementById('chatOffline').style.display = 'none';
  };

  chatWs.onmessage = (e) => {
    try {
      const data = JSON.parse(e.data);
      if (data.type === 'history') {
        document.getElementById('chatMsgs').innerHTML = '';
        document.getElementById('chatOffline').style.display = 'none';
        resetChatState();
        data.messages.forEach(m => appendMsg(m));
        scrollChat();
      } else if (data.type === 'message') {
        appendMsg(data);
        scrollChat();
      } else if (data.type === 'system') {
        appendSystem(data.text);
        scrollChat();
      } else if (data.type === 'users') {
        const count = data.count || 0;
        document.getElementById('onlineCount').textContent = count + ' online';
        document.getElementById('onlineBadge').textContent = count;
      }
    } catch(e) {}
  };

  chatWs.onclose = () => {
    chatConnected = false;
    // Reconnect after 3s
    setTimeout(() => { if (chatInited) connectChat(); }, 3000);
  };

  chatWs.onerror = () => { chatWs.close(); };
}

let lastMsgSender = null;
let lastMsgTime = 0;
let lastMsgDate = '';

function appendMsg(msg) {
  const myEmail = G.user?.email || '';
  const isOwn = msg.email === myEmail;
  const initials = (msg.displayName || '?').slice(0,2).toUpperCase();
  const msgDate = new Date(msg.ts).toLocaleDateString([], {weekday:'long',month:'long',day:'numeric'});
  const time = new Date(msg.ts).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
  const msgsEl = document.getElementById('chatMsgs');
  const timeDiff = msg.ts - lastMsgTime;
  const sameUser = lastMsgSender === msg.email && timeDiff < 5*60*1000;

  // Date divider
  if (msgDate !== lastMsgDate) {
    const datDiv = document.createElement('div');
    datDiv.className = 'chat-date-divider';
    datDiv.innerHTML = `<span>${msgDate}</span>`;
    msgsEl.appendChild(datDiv);
    lastMsgDate = msgDate;
    lastMsgSender = null; // force new header after date break
  }

  const div = document.createElement('div');
  if (!sameUser) {
    // Full message with avatar and name
    div.className = 'chat-msg';
    div.innerHTML = `
      <div class="chat-avatar ${isOwn?'own':''}">${initials}</div>
      <div class="chat-bubble">
        <div class="chat-name">
          <span class="${isOwn?'chat-name-own':''}">${esc(msg.displayName)}</span>
          ${isOwn?'<span class="you-tag">you</span>':''}
          <span class="chat-time">${time}</span>
        </div>
        <div class="chat-text">${esc(msg.text).replace(/\n/g,'<br>')}</div>
      </div>`;
  } else {
    // Compact continuation — no avatar/name repeat
    div.className = 'chat-msg-cont';
    div.innerHTML = `
      <div class="chat-cont-time">${time}</div>
      <div class="chat-text">${esc(msg.text).replace(/\n/g,'<br>')}</div>`;
  }
  msgsEl.appendChild(div);
  lastMsgSender = msg.email;
  lastMsgTime = msg.ts;
}

function resetChatState() {
  lastMsgSender = null;
  lastMsgTime = 0;
  lastMsgDate = '';
}

function appendSystem(text) {
  const msgsEl = document.getElementById('chatMsgs');
  const div = document.createElement('div');
  div.className = 'chat-system';
  div.textContent = text;
  msgsEl.appendChild(div);
}

function scrollChat() {
  const el = document.getElementById('chatMsgs');
  el.scrollTop = el.scrollHeight;
}

function sendChatMsg() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text) return;
  if (!chatConnected || !chatWs || chatWs.readyState !== WebSocket.OPEN) {
    showToast('Not connected to chat — reconnecting…','e');
    connectChat();
    return;
  }
  chatWs.send(JSON.stringify({ type: 'message', text }));
  input.value = '';
  input.style.height = 'auto';
}

function insertTopic(topic) {
  const input = document.getElementById('chatInput');
  input.value = topic + ': ';
  input.focus();
}

// ── ACCOUNT SETTINGS ──────────────────────────────────────────────────────
async function loadUsage() {
  try {
    const res = await api('/api/usage','GET');
    if (res.error) return;
    const pct = res.limit >= 999999 ? 0 : Math.round((res.used/res.limit)*100);
    document.getElementById('usageUsed').textContent = res.used;
    document.getElementById('usageRemaining').textContent = res.limit >= 999999 ? '∞' : res.remaining;
    document.getElementById('usageLimit').textContent = res.limit >= 999999 ? '∞' : res.limit;
    document.getElementById('usageBar').style.width = Math.min(pct,100)+'%';
    document.getElementById('usageBar').style.background = pct > 80 ? 'linear-gradient(90deg,var(--yellow),var(--red))' : 'linear-gradient(90deg,var(--accent),var(--accent2))';
    document.getElementById('usageLabel').textContent = res.limit >= 999999 ? 'Unlimited plan — no daily cap' : `${pct}% of daily limit used — resets at midnight`;
    document.getElementById('currentEmailDisplay').textContent = G.user?.email || '—';

    // Low credits warning — show when ≤500 remaining and not unlimited
    if (res.limit < 999999 && res.remaining <= 500 && res.remaining > 0) {
      const warn = document.getElementById('lowCreditsWarn');
      document.getElementById('lowCreditsMsg').textContent = `Only ${res.remaining} searches left today. Resets at midnight.`;
      warn.style.display = 'flex';
    }
  } catch(e) { console.warn('Usage load failed:', e); }
}

async function saveProfile() {
  const newEmail = document.getElementById('newEmail').value.trim();
  const newPassword = document.getElementById('newPassword').value;
  const currentPassword = document.getElementById('currentPassword').value;
  const errEl = document.getElementById('profileErr');
  const okEl = document.getElementById('profileOk');
  const btn = document.getElementById('saveProfileBtn');

  errEl.style.display='none'; okEl.style.display='none';

  if (!currentPassword) { errEl.textContent='Enter your current password to save changes'; errEl.style.display='block'; return; }
  if (!newEmail && !newPassword) { errEl.textContent='Enter a new email or new password to update'; errEl.style.display='block'; return; }

  btn.disabled=true; btn.textContent='Saving…';
  try {
    const res = await api('/api/update-profile','POST',{ newEmail:newEmail||undefined, newPassword:newPassword||undefined, currentPassword });
    if (res.error) { errEl.textContent=res.error; errEl.style.display='block'; return; }
    // Update session with new token
    G.token=res.token;
    G.user={...G.user, email:res.email, plan:res.plan, planLabel:res.planLabel};
    localStorage.setItem('lg_token',res.token);
    localStorage.setItem('lg_user',JSON.stringify(G.user));
    updatePlanUI();
    okEl.textContent='✓ Profile updated successfully!'; okEl.style.display='block';
    document.getElementById('currentEmailDisplay').textContent=res.email;
    document.getElementById('newEmail').value='';
    document.getElementById('newPassword').value='';
    document.getElementById('currentPassword').value='';
    showToast('Profile updated','s');
  } catch(e) { errEl.textContent='Network error — try again'; errEl.style.display='block'; }
  finally { btn.disabled=false; btn.textContent='Save Changes'; }
}

