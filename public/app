    <tr onclick="openD('${esc(l.id)}','bulk')">
      <td></td>
      <td class="nm">${esc(l.name)}</td><td class="mu">${esc(l.cat)}</td>
      <td class="mu">${esc(l.phone)||'—'}</td>
      <td class="lk">${l.website?`<a href="${esc(l.website)}" target="_blank" onclick="event.stopPropagation()">${esc(l.website.replace(/^https?:\/\//,'').slice(0,22))}</a>`:'—'}</td>
