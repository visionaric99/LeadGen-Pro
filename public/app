  if(res.error){showToast('Error: '+res.error,'e');return;}
  window.location.href=res.url;
}

// ── SEARCH ─────────────────────────────────────────────────────────────────
async function runSearch() {
  const q=document.getElementById('q').value.trim(), loc=document.getElementById('loc').value.trim();
  const minR=parseFloat(document.getElementById('minR').value);
  if(!q||!loc){showToast('Enter a business type and city','i');return;}
  document.getElementById('es').style.display='none';
  document.getElementById('tw').style.display='none';
  document.getElementById('rhdr').style.display='none';
  document.getElementById('eb').classList.remove('on');
  const pw=document.getElementById('pw'); pw.classList.add('on');
  setProg('pfill','ppct','ptxt',20,'Searching Google Maps…');
  const btn=document.getElementById('searchBtn'); btn.disabled=true;
  try {
    const limit=document.getElementById('searchLimit')?.value||'20';
    const noWebsite=G.filters.noWebsite;
    const filterParam=noWebsite?'&noWebsite=true':'';
    const res=await api(`/api/search?q=${encodeURIComponent(q)}&loc=${encodeURIComponent(loc)}&limit=${limit}${filterParam}`,'GET');
    setProg('pfill','ppct','ptxt',100,'Done!');
    if(res.error){pw.classList.remove('on');showEb(res.error,'eb');return;}
    let leads=res.leads||[];
    if(minR>0) leads=leads.filter(l=>l.rating>=minR);
    // Filter out archived
    const arcIds=new Set(G.archived.map(a=>a.id));
    leads=leads.filter(l=>!arcIds.has(l.id));
    G.leads=leads; G.sel.clear(); G.exportLimit=res.exportLimit||0;
    setTimeout(()=>{ pw.classList.remove('on'); if(res.debug||res.errors?.length) showEb((res.debug||res.errors.join(' | ')),'eb'); leads.length?renderLeads():showEmpty('es','No results found','Try a different term or city. Check the red error above.');
      checkCreditsAfterSearch(); },300);
  } catch(e){ pw.classList.remove('on'); showEb('Search failed: '+e.message,'eb'); }
  finally{ btn.disabled=false; }
}

// ── BULK SEARCH ────────────────────────────────────────────────────────────
function initBulkRows() {
  G.bulkRows=[{q:'',loc:''},{q:'',loc:''}];
  renderBulkRows();
}

function renderBulkRows() {
  document.getElementById('bulkRows').innerHTML=G.bulkRows.map((r,i)=>`
    <div class="bulk-row">
      <div class="fld"><label>${i===0?'Business Type':''}</label><input type="text" value="${esc(r.q)}" placeholder="dentist, plumber…" oninput="G.bulkRows[${i}].q=this.value" onkeydown="if(event.key==='Enter')runBulkSearch()"></div>
      <div class="fld"><label>${i===0?'City / Location':''}</label><input type="text" value="${esc(r.loc)}" placeholder="Miami FL…" oninput="G.bulkRows[${i}].loc=this.value" onkeydown="if(event.key==='Enter')runBulkSearch()"></div>
      <div class="fld"><label>${i===0?'&nbsp;':''}</label><button class="btn btn-d" style="padding:7px 10px;font-size:12px" onclick="removeBulkRow(${i})">✕</button></div>
    </div>`).join('');
}

function addBulkRow() { G.bulkRows.push({q:'',loc:''}); renderBulkRows(); }
function removeBulkRow(i) { if(G.bulkRows.length>1){G.bulkRows.splice(i,1);renderBulkRows();} }

async function runBulkSearch() {
  const rows=G.bulkRows.filter(r=>r.q.trim()&&r.loc.trim());
  if(!rows.length){showToast('Add at least one search row','i');return;}
  document.getElementById('bulkEmpty').style.display='none';
  document.getElementById('bulkTw').style.display='none';
  document.getElementById('bulkRhdr').style.display='none';
  document.getElementById('bulkEb').classList.remove('on');
  const pw=document.getElementById('bulkPw'); pw.classList.add('on');
  const btn=document.getElementById('bulkBtn'); btn.disabled=true;
  G.bulkLeads=[];
  const arcIds=new Set(G.archived.map(a=>a.id));
  for(let i=0;i<rows.length;i++){
    const r=rows[i];
    const pct=Math.round(((i)/rows.length)*90)+5;
    setProg('bulkPfill','bulkPpct','bulkPtxt',pct,`Searching ${r.q} in ${r.loc}… (${i+1}/${rows.length})`);
    try {
      const res=await api(`/api/search?q=${encodeURIComponent(r.q)}&loc=${encodeURIComponent(r.loc)}&limit=20`,'GET');
      const leads=(res.leads||[]).filter(l=>!arcIds.has(l.id)).map(l=>({...l,_search:`${r.q} / ${r.loc}`}));
      G.bulkLeads.push(...leads);
    } catch(e){ console.warn('Bulk row failed:',e.message); }
  }
  // Dedupe
  const seen=new Set();
  G.bulkLeads=G.bulkLeads.filter(l=>{ const k=(l.name+l.city).toLowerCase().replace(/\s/g,''); if(seen.has(k))return false; seen.add(k);return true; });
  setProg('bulkPfill','bulkPpct','bulkPtxt',100,'Done!');
  setTimeout(()=>{
    pw.classList.remove('on');
    if(G.bulkLeads.length) renderBulkLeads();
    else showEmpty('bulkEmpty','No results','Try different search terms or cities.');
    btn.disabled=false;
  },300);
}

